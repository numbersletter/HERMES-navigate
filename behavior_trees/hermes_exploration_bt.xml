<?xml version="1.0"?>
<!--
  HERMES Exploration Behavior Tree
  =================================
  Entry point: loaded by HermesNavigateNode on on_configure().

  Lifecycle / service behaviour:
    CONFIGURED  → Tree is loaded but NOT ticked. Robot is stationary.
    ACTIVE      → Tick timer starts. Exploration branch runs.
    DEACTIVATED → Tick timer stops; tree is halted (paused). Robot stays put.
    ~/stop srv  → Sets return_to_start=true and restarts tick timer so the
                   ReturnBranch executes and the robot retraces its breadcrumb
                   trail back to the start pose via navigate_through_poses.

  Tree structure (top-level Fallback):
  ┌─ Fallback (MainFallback)
  │   │
  │   ├─ [Return branch]  Sequence
  │   │     ReturnToStartCondition(return_to_start)
  │   │     ReturnToStart(start_pose, breadcrumbs → waypoints)
  │   │       └─ Reverses breadcrumb trail + appends start_pose
  │   │     NavigateThroughWaypoints(waypoints)
  │   │       └─ Sends reversed trail to navigate_through_poses action server
  │   │
  │   └─ [Exploration branch]  PipelineSequence
  │         ├─ RateController(1 Hz)
  │         │     Sequence
  │         │       SearchFrontiers   ← WavefrontFrontierDetector plugin
  │         │       AssignCosts       ← InformationGainPlugin + EuclideanPlugin
  │         │       SelectFrontier    ← hysteresis-based goal selection
  │         └─ ForceSuccess
  │               RetryUntilSuccessful(num_attempts=3)
  │                 NavigateToFrontier(nav_goal) ← navigate_to_pose action server

  Blackboard entries (written by HermesNavigateNode before the first tick):
    start_pose       (geometry_msgs/PoseStamped)        — captured at configure
    return_to_start  (bool)                              — true when ~/stop called
    exploration_done (bool)                              — set by SelectFrontier
    robot_pose       (geometry_msgs/PoseStamped)         — updated every tick
    nav_goal         (geometry_msgs/PoseStamped)         — written by SelectFrontier
    breadcrumbs      (vector<geometry_msgs/PoseStamped>) — trail recorded each tick
    return_waypoints (vector<geometry_msgs/PoseStamped>) — set by ReturnToStart
-->
<root BTCPP_format="4" main_tree_to_execute="HermesExplorationBT">

  <BehaviorTree ID="HermesExplorationBT">

    <!--
      Top-level Fallback: the return-to-start branch is tried first every tick.
      If return_to_start is false the condition immediately fails and the
      exploration pipeline runs instead.
    -->
    <Fallback name="MainFallback">

      <!-- ─── Return-to-Start branch ───────────────────────────────────────
           Fires when the ~/stop service sets return_to_start=true.
           ReturnToStart builds the reversed breadcrumb waypoints list;
           NavigateThroughWaypoints drives the robot home via nav2's
           navigate_through_poses action (waypoints WE supply, not nav2-planned).
      -->
      <Sequence name="ReturnBranch">
        <ReturnToStartCondition return_to_start="{return_to_start}"/>
        <ReturnToStart
          start_pose="{start_pose}"
          breadcrumbs="{breadcrumbs}"
          waypoints="{return_waypoints}"/>
        <NavigateThroughWaypoints waypoints="{return_waypoints}"/>
      </Sequence>

      <!-- ─── Exploration pipeline ─────────────────────────────────────── -->
      <PipelineSequence name="ExplorationPipeline">

        <!-- Rate-limited frontier search + scoring ──────────────────────── -->
        <RateController hz="1.0">
          <Sequence>

            <!-- 1. Search for frontier clusters (incremental wavefront BFS) -->
            <SearchFrontiers
              robot_pose="{robot_pose}"
              frontiers="{frontiers}"/>

            <!-- 2. Score each frontier using InformationGain + Euclidean -->
            <AssignCosts
              frontiers="{frontiers}"
              robot_pose="{robot_pose}"
              scored_frontiers="{scored_frontiers}"/>

            <!-- 3. Select best frontier as nav goal (with hysteresis) -->
            <SelectFrontier
              scored_frontiers="{scored_frontiers}"
              robot_pose="{robot_pose}"
              goal="{nav_goal}"
              exploration_done="{exploration_done}"/>

          </Sequence>
        </RateController>

        <!-- Navigation to the selected frontier goal ─────────────────────
          ForceSuccess wrapping RetryUntilSuccessful: NavigateToFrontier is
          retried up to 3 times on failure (obstacle, timeout, etc.).
          If all 3 attempts fail ForceSuccess converts FAILURE to SUCCESS,
          allowing the pipeline to re-run the goal-selection step on the next
          tick and pick a new goal.
        -->
        <ForceSuccess>
          <RetryUntilSuccessful num_attempts="3">
            <NavigateToFrontier goal="{nav_goal}"/>
          </RetryUntilSuccessful>
        </ForceSuccess>

      </PipelineSequence>

    </Fallback>

  </BehaviorTree>

</root>

