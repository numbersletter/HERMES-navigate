<?xml version="1.0"?>
<!--
  HERMES Exploration Behavior Tree
  =================================
  Entry point: loaded by HermesNavigateNode on on_configure().

  Lifecycle / service behaviour:
    CONFIGURED  → Tree is loaded but NOT ticked. Robot is stationary.
    ACTIVE      → Tick timer starts. Exploration branch runs.
    DEACTIVATED → Tick timer stops; tree is halted (paused). Robot stays put.
    ~/stop srv  → Sets return_to_start=true. The ReactiveFallback re-evaluates
                   the ReturnBranch on the very next tick, immediately halting
                   exploration. ReturnToStart sets nav_goal to the recorded
                   start pose and Nav2's NavigateToPose drives the robot home.

  Tree structure (top-level ReactiveFallback):
  ┌─ ReactiveFallback (MainFallback)
  │   │
  │   │   Re-evaluates child 1 (ReturnBranch) from the top on EVERY tick.
  │   │   During exploration ReturnBranch fails and the fallback falls through
  │   │   to child 2. The moment ~/stop sets return_to_start=true the condition
  │   │   succeeds, exploration is halted, and the robot navigates home.
  │   │
  │   ├─ [Return branch]  Sequence
  │   │     ReturnToStartCondition(return_to_start)
  │   │     ReturnToStart(start_pose → nav_goal)  ← sets goal, no navigation
  │   │     NavigateToPose(nav_goal)              ← Nav2 built-in; plans path
  │   │
  │   └─ KeepRunningUntilFailure
  │         │
  │         │   Converts a PipelineSequence SUCCESS (one navigation leg finished)
  │         │   into RUNNING so the tree never terminates between legs. The tree
  │         │   stays alive and naturally ticks the RateController again, which
  │         │   triggers a fresh frontier selection. The tree only terminates
  │         │   (FAILURE) when SelectFrontier sets exploration_done=true.
  │         │
  │         └─ [Exploration branch]  PipelineSequence
  │               ├─ RateController(1 Hz)
  │               │     Sequence
  │               │       SearchFrontiers   ← WavefrontFrontierDetector plugin
  │               │       AssignCosts       ← InformationGainPlugin + EuclideanPlugin
  │               │       SelectFrontier    ← hysteresis selection, skips blacklist;
  │               │                            writes nav_goal directly to blackboard
  │               └─ ForceSuccess (NavAndMark)
  │                     Fallback
  │                       RetryUntilSuccessful(num_attempts=3)
  │                         NavigateToPose(nav_goal)  ← Nav2 built-in; 3 attempts
  │                       BlacklistFrontier(nav_goal) ← ONLY on failure: marks frontier
  │                                                      unreachable so it is skipped

  Blackboard entries (written by HermesNavigateNode before the first tick):
    start_pose        (geometry_msgs/PoseStamped) — captured at configure
    return_to_start   (bool)                      — true when ~/stop is called
    exploration_done  (bool)                      — set by SelectFrontier
    robot_pose        (geometry_msgs/PoseStamped) — updated every tick
    nav_goal          (geometry_msgs/PoseStamped) — written by SelectFrontier
                                                    or ReturnToStart
    blacklisted_goals (vector<PoseStamped>)       — grown by BlacklistFrontier on
                                                     nav failure; read and trimmed
                                                     by SelectFrontier
-->
<root BTCPP_format="4" main_tree_to_execute="HermesExplorationBT">

  <BehaviorTree ID="HermesExplorationBT">

    <!--
      Top-level ReactiveFallback: re-evaluates child 1 (ReturnBranch) from the
      top on EVERY tick. During exploration ReturnBranch fails (condition false)
      and the fallback falls through to the KeepRunningUntilFailure exploration
      branch. The moment ~/stop sets return_to_start=true, the condition
      succeeds on the next tick, the exploration child is halted, and the robot
      navigates home. Exploration itself never returns SUCCESS to this node
      (KeepRunningUntilFailure converts each successful navigation leg to
      RUNNING), so the tree only terminates when SelectFrontier declares
      exploration_done (FAILURE) or the return journey is complete (SUCCESS).
    -->
    <ReactiveFallback name="MainFallback">

      <!-- ─── Return-to-Start branch ───────────────────────────────────────
           Fires when the ~/stop service sets return_to_start=true.
           ReturnToStart writes start_pose to nav_goal; Nav2's NavigateToPose
           BT node then calls the navigate_to_pose action server and lets Nav2
           plan the path home autonomously.
      -->
      <Sequence name="ReturnBranch">
        <ReturnToStartCondition return_to_start="{return_to_start}"/>
        <ReturnToStart start_pose="{start_pose}" goal="{nav_goal}"/>
        <NavigateToPose goal="{nav_goal}"/>
      </Sequence>

      <!-- ─── Exploration pipeline ─────────────────────────────────────── -->
      <!-- KeepRunningUntilFailure converts a successful navigation leg (PipelineSequence
           returns SUCCESS) into RUNNING, so the tree never terminates prematurely.
           The tree stays alive and ticks the RateController again, which triggers
           a fresh frontier selection. Exploration terminates (FAILURE) only when
           SelectFrontier sets exploration_done=true and returns FAILURE. -->
      <KeepRunningUntilFailure>
        <PipelineSequence name="ExplorationPipeline">

          <!-- Rate-limited frontier search + scoring + goal selection ──────── -->
          <RateController hz="1.0">
            <Sequence>

              <!-- 1. Search for frontier clusters (incremental wavefront BFS) -->
              <SearchFrontiers
                robot_pose="{robot_pose}"
                frontiers="{frontiers}"/>

              <!-- 2. Score each frontier using InformationGain + Euclidean -->
              <AssignCosts
                frontiers="{frontiers}"
                robot_pose="{robot_pose}"
                scored_frontiers="{scored_frontiers}"/>

              <!-- 3. Select best non-blacklisted frontier (with hysteresis).
                   Writes the chosen pose directly to nav_goal so the downstream
                   NavigateToPose node (Nav2 built-in) can navigate there. -->
              <SelectFrontier
                scored_frontiers="{scored_frontiers}"
                robot_pose="{robot_pose}"
                blacklisted_goals="{blacklisted_goals}"
                nav_goal="{nav_goal}"
                exploration_done="{exploration_done}"/>

            </Sequence>
          </RateController>

          <!-- Navigation — blacklist only on failure ──────────────────────────
            ForceSuccess (NavAndMark):
              A Fallback with two children:
                Child 1 — RetryUntilSuccessful:
                             Tries to navigate up to 3 times.
                             Returns SUCCESS if any attempt succeeds.
                             Returns FAILURE only after all attempts fail.
                Child 2 — BlacklistFrontier:
                             Only reached when all 3 nav attempts failed.
                             Marks the frontier unreachable so it is skipped
                             on future ticks.  Always returns SUCCESS so the
                             Fallback (and ForceSuccess) return SUCCESS too.

            On navigation SUCCESS the Fallback short-circuits at child 1 and
            BlacklistFrontier never runs.  Blacklisting on success is
            unnecessary: once the robot reaches a frontier its sensors map the
            area, and the wavefront detector naturally stops reporting that
            position as a frontier on the next update.

            ForceSuccess ensures NavAndMark always returns SUCCESS so the
            PipelineSequence returns SUCCESS (one leg done). The enclosing
            KeepRunningUntilFailure then converts that SUCCESS into RUNNING,
            keeping the tree alive for the next frontier selection.
          -->
          <ForceSuccess name="NavAndMark">
            <Fallback>
              <RetryUntilSuccessful num_attempts="3">
                <NavigateToPose goal="{nav_goal}"/>
              </RetryUntilSuccessful>
              <!-- Only reached when all 3 attempts failed: -->
              <BlacklistFrontier
                goal="{nav_goal}"
                blacklisted_goals="{blacklisted_goals}"/>
            </Fallback>
          </ForceSuccess>

        </PipelineSequence>
      </KeepRunningUntilFailure>

    </ReactiveFallback>

  </BehaviorTree>

</root>

