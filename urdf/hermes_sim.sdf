<?xml version="1.0"?>
<!--
  hermes_sim.sdf
  ==============
  Simulation SDF model for the HERMES differential-drive robot.
  Designed for Gazebo Harmonic (gz-sim) with ROS 2 Jazzy.

  Robot geometry
  ==============
    Body:         cube  5.5 x 5.5 x 5.5 in  (0.1397 x 0.1397 x 0.1397 m)
    Drive wheels: diameter 2.6 in (r = 0.0330 m), width 0.7 in (0.0178 m)
    Caster:       sphere, radius = wheel_radius/2 = 0.0165 m, placed at FRONT

  Wheel parameterisation (y_reflect)
  ===================================
    left  wheel: y_reflect = +1  =>  y = +0.0788 m
    right wheel: y_reflect = -1  =>  y = -0.0788 m
    Both wheels share identical geometry; only the signed y position differs.
    x_reflect is unused (wheels centred at x = 0 on the body).

  Key dimensions (all metres)
  ===========================
    body_size      = 0.1397   (5.5 in)
    wheel_radius   = 0.0330   (1.3 in)
    wheel_width    = 0.0178   (0.7 in)
    wheel_y        = body_size/2 + wheel_width/2 = 0.0699 + 0.0089 = 0.0788
    wheel_sep      = 2 x wheel_y = 0.1575   (centre-to-centre)
    caster_radius  = wheel_radius / 2 = 0.0165
    body_z_spawn   = wheel_radius + body_size/2 = 0.0330 + 0.0699 = 0.1029
                     (body bottom sits at wheel_radius above ground; wheels touch ground)

  TF tree produced at runtime
  ===========================
    odom  <- (DiffDrive plugin via /tf bridge)
      base_link
        base_footprint   (virtual, at ground level, child of base_link)
        wheel_left_link
        wheel_right_link
        caster_link      (front caster)
        laser_frame      (LiDAR on top of body)
        camera_frame     (camera at front-top of body)

  Topics
  ======
    /cmd_vel       geometry_msgs/Twist    => drive command  (ROS => gz)
    /odom          nav_msgs/Odometry      <= wheel odometry (gz => ROS)
    /scan          sensor_msgs/LaserScan  <= 360 deg LiDAR  (gz => ROS)
    /tf            tf2_msgs/TFMessage     <= odom->base_link (gz => ROS)
    /joint_states  sensor_msgs/JointState <= wheel joints   (gz => ROS)
-->
<sdf version="1.9">
  <model name="hermes">

    <!-- ── base_link (cube body) ──────────────────────────────────────────── -->
    <link name="base_link">
      <inertial>
        <mass>5.0</mass>
        <!-- Solid cube: I = m·s²/6 = 5.0·0.1397²/6 ≈ 0.01627 each axis -->
        <inertia>
          <ixx>0.01627</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.01627</iyy><iyz>0</iyz>
          <izz>0.01627</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <box><size>0.1397 0.1397 0.1397</size></box>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <box><size>0.1397 0.1397 0.1397</size></box>
        </geometry>
      </collision>
    </link>

    <!-- ── base_footprint (virtual, at ground level — child of base_link) ─── -->
    <!--   z offset = -(wheel_radius + body_size/2) = -0.1029 m              -->
    <link name="base_footprint">
      <pose relative_to="base_link">0 0 -0.1029 0 0 0</pose>
    </link>

    <joint name="base_footprint_joint" type="fixed">
      <parent>base_link</parent>
      <child>base_footprint</child>
    </joint>

    <!-- ── Drive wheels ──────────────────────────────────────────────────────
         Both wheels are identical cylinders differing only in the y sign
         (y_reflect parameter).  Wheel axis = Y in the model frame.

           left  wheel:  y_reflect = +1  →  y = +0.0788 m
           right wheel:  y_reflect = -1  →  y = -0.0788 m

         z = -body_size/2 = -0.0699 m  (wheel axis at bottom face of body,
             which is wheel_radius = 0.0330 m above ground when spawned at
             body_z_spawn = 0.1029 m).
    ── ────────────────────────────────────────────────────────────────────── -->

    <!-- Left wheel  (y_reflect = +1) -->
    <link name="wheel_left_link">
      <pose relative_to="base_link">0 0.0788 -0.0699 1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <!-- Solid cylinder: Ixx=Iyy=m(3r²+h²)/12, Izz=mr²/2 -->
        <inertia>
          <ixx>0.000149</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000149</iyy><iyz>0</iyz>
          <izz>0.000272</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.0330</radius><length>0.0178</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.0330</radius><length>0.0178</length></cylinder>
        </geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
    </link>

    <joint name="wheel_left_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_left_link</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
      </axis>
    </joint>

    <!-- Right wheel  (y_reflect = -1) -->
    <link name="wheel_right_link">
      <!-- identical to wheel_left_link; y sign negated (y_reflect = -1) -->
      <pose relative_to="base_link">0 -0.0788 -0.0699 1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.000149</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000149</iyy><iyz>0</iyz>
          <izz>0.000272</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.0330</radius><length>0.0178</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.0330</radius><length>0.0178</length></cylinder>
        </geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
    </link>

    <joint name="wheel_right_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_right_link</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
      </axis>
    </joint>

    <!-- ── Caster wheel (FRONT, passive, zero friction) ───────────────────── -->
    <!--   x  = body_size/2 - caster_radius = 0.0699 - 0.0165 = 0.0534 m    -->
    <!--   z  = caster_radius - body_z_spawn = 0.0165 - 0.1029 = -0.0864 m  -->
    <link name="caster_link">
      <pose relative_to="base_link">0.0534 0 -0.0864 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <!-- Solid sphere: I = 2mr²/5 -->
        <inertia>
          <ixx>0.00001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00001</iyy><iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <sphere><radius>0.0165</radius></sphere>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <sphere><radius>0.0165</radius></sphere>
        </geometry>
        <surface>
          <friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction>
        </surface>
      </collision>
    </link>

    <joint name="caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster_link</child>
    </joint>

    <!-- ── laser_frame (2-D LiDAR, on top of body) ───────────────────────── -->
    <!--   z = +body_size/2 = +0.0699 m relative to base_link centre         -->
    <!--   Absolute scan height = body_z_spawn + 0.0699 = 0.173 m AGL        -->
    <link name="laser_frame">
      <pose relative_to="base_link">0 0 0.0699 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.00001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00001</iyy><iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.04</radius><length>0.04</length></cylinder>
        </geometry>
        <material>
          <ambient>0.0 0.4 0.8 1</ambient>
          <diffuse>0.0 0.4 0.8 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.04</radius><length>0.04</length></cylinder>
        </geometry>
      </collision>
      <!-- 2-D LiDAR (360°, 10 Hz, 12 m range) -->
      <sensor name="lidar" type="gpu_lidar">
        <topic>/scan</topic>
        <update_rate>10</update_rate>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159265</min_angle>
              <max_angle>3.14159265</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.10</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </link>

    <joint name="laser_joint" type="fixed">
      <parent>base_link</parent>
      <child>laser_frame</child>
    </joint>

    <!-- ── camera_frame (front-top corner of body) ───────────────────────── -->
    <!--   x = body_size/2 = 0.0699 m (front face)                           -->
    <!--   z = body_size/2 = 0.0699 m (top face)                             -->
    <link name="camera_frame">
      <pose relative_to="base_link">0.0699 0 0.0699 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00001</iyy><iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <box><size>0.03 0.03 0.03</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.1 0.1 1</ambient>
          <diffuse>0.8 0.1 0.1 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_frame</child>
    </joint>

    <!-- ══════════════════════════════════════════════════════════════════════
         Gazebo Harmonic (gz-sim) plugins
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Differential drive controller -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.1575</wheel_separation>
      <wheel_radius>0.0330</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <min_velocity>-0.5</min_velocity>
      <max_velocity>0.5</max_velocity>
      <min_acceleration>-1.0</min_acceleration>
      <max_acceleration>1.0</max_acceleration>
    </plugin>

    <!-- Joint state publisher for wheel joints -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>wheel_left_joint</joint_name>
      <joint_name>wheel_right_joint</joint_name>
    </plugin>

  </model>
</sdf>
