<?xml version="1.0"?>
<!--
  hermes_robot.urdf.xacro
  =======================
  URDF description of the HERMES differential-drive robot for use on the
  real hardware. This mirrors the geometry defined in hermes_sim.sdf.xacro
  but omits Gazebo-specific plugins and uses standard URDF format so that
  robot_state_publisher and joint_state_publisher can consume it directly.

  Joints
  ------
    base_joint        (fixed)      base_link -> base_footprint
    drivewhl_l_joint  (continuous) base_link -> drivewhl_l_link
    drivewhl_r_joint  (continuous) base_link -> drivewhl_r_link
    caster_joint      (fixed)      base_link -> front_caster
    lidar_joint       (fixed)      base_link -> lidar_link
-->
<robot name="hermes_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Robot constants (must match hermes_sim.sdf.xacro) -->
  <xacro:property name="base_width"   value="0.1143"/>
  <xacro:property name="base_length"  value="0.1143"/>
  <xacro:property name="base_height"  value="0.0762"/>

  <xacro:property name="wheel_radius" value="0.03302"/>
  <xacro:property name="wheel_width"  value="0.01778"/>
  <xacro:property name="wheel_ygap"   value="0.01"/>
  <xacro:property name="wheel_zoff"   value="0.01778"/>
  <xacro:property name="wheel_xoff"   value="0.03"/>

  <xacro:property name="caster_xoff"  value="0.04"/>

  <!-- Inertia helpers -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0"
        iyy="${(m/12) * (w*w + d*d)}" iyz="0.0"
        izz="${(m/12) * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12) * (3*r*r + h*h)}" ixy="0.0" ixz="0.0"
        iyy="${(m/12) * (3*r*r + h*h)}" iyz="0.0"
        izz="${(m/2) * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(2/5) * m * (r*r)}" ixy="0.0" ixz="0.0"
        iyy="${(2/5) * m * (r*r)}" iyz="0.0"
        izz="${(2/5) * m * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <!-- ── Base link ─────────────────────────────────────────────────────────── -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="cyan">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="2.0" w="${base_width}" h="${base_height}" d="${base_length}"/>
  </link>

  <!-- ── Base footprint ───────────────────────────────────────────────────── -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 ${-(wheel_radius + wheel_zoff)}" rpy="0 0 0"/>
  </joint>

  <!-- ── Drive wheels ─────────────────────────────────────────────────────── -->
  <!--
    The drive wheels are continuous (no hard travel limits).
    joint_state_publisher will publish 0.0 for these joints until a hardware
    driver populates /joint_states for them.
  -->
  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark_grey">
          <color rgba="0.3 0.3 0.3 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_link"/>
      <origin
        xyz="${x_reflect * wheel_xoff} ${y_reflect * (base_width/2 + wheel_ygap)} ${-wheel_zoff}"
        rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="drivewhl_l" x_reflect="-1" y_reflect="1"/>
  <xacro:wheel prefix="drivewhl_r" x_reflect="-1" y_reflect="-1"/>

  <!-- ── Front caster ─────────────────────────────────────────────────────── -->
  <link name="front_caster">
    <visual>
      <geometry>
        <sphere radius="${wheel_radius + wheel_zoff - (base_height/2)}"/>
      </geometry>
      <material name="cyan">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${wheel_radius + wheel_zoff - (base_height/2)}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="0.5" r="${wheel_radius + wheel_zoff - (base_height/2)}"/>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="${caster_xoff} 0.0 ${-(base_height/2)}" rpy="0 0 0"/>
  </joint>

  <!-- ── Lidar ─────────────────────────────────────────────────────────────── -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.021" length="0.02032"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.021" length="0.02032"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.125" r="0.021" h="0.02032"/>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0.0 0.04826" rpy="0 0 0"/>
  </joint>

</robot>
