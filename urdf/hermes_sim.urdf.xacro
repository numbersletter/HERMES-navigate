<?xml version="1.0"?>
<!--
  hermes_sim.urdf.xacro
  =====================
  Simulation URDF for the HERMES differential-drive robot.
  Designed for Gazebo Harmonic (gz-sim) with ROS 2 Jazzy.

  Robot geometry (matches hermes_sim.sdf exactly)
  ------------------------------------------------
    Body:         cube  5.5 × 5.5 × 5.5 in  (0.1397 × 0.1397 × 0.1397 m)
    Drive wheels: diameter 2.6 in (r = 0.0330 m), width 0.7 in (0.0178 m)
    Caster:       sphere, radius = wheel_radius/2 = 0.0165 m, placed at FRONT
    body_z_spawn  = wheel_radius + body_size/2 = 0.0330 + 0.0699 = 0.1029 m

  TF tree produced at runtime
  ---------------------------
    odom  ←─ (DiffDrive plugin via /tf bridge)
      └── base_footprint   (ground level)
            └── base_link  (body centre, 0.1029 m AGL)
                  ├── wheel_left_link
                  ├── wheel_right_link
                  ├── caster_link
                  ├── laser_frame   (LiDAR at z=+0.0699 m from base_link)
                  └── camera_frame  (camera at x=0.0699, z=+0.0699 m)

  Topics
  ------
    /cmd_vel          geometry_msgs/Twist   → drive command (ROS → gz)
    /odom             nav_msgs/Odometry     ← wheel odometry  (gz → ROS)
    /scan             sensor_msgs/LaserScan ← 360° LiDAR      (gz → ROS)
    /tf               tf2_msgs/TFMessage    ← odom→base_footprint (gz → ROS)
    /joint_states     sensor_msgs/JointState ← wheel joints   (gz → ROS)
-->
<robot name="hermes" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ── Constants (mirror hermes_sim.sdf) ───────────────────────────────── -->
  <xacro:property name="PI"               value="3.14159265359"/>
  <xacro:property name="body_size"        value="0.1397"/>  <!-- cube side, m -->
  <xacro:property name="wheel_radius"     value="0.0330"/>  <!-- m -->
  <xacro:property name="wheel_width"      value="0.0178"/>  <!-- m -->
  <xacro:property name="wheel_y"          value="0.0788"/>  <!-- body_size/2 + wheel_width/2 -->
  <xacro:property name="wheel_separation" value="0.1575"/>  <!-- 2 × wheel_y, m -->
  <xacro:property name="caster_radius"    value="0.0165"/>  <!-- wheel_radius/2, m -->
  <!-- body_z_spawn: height of base_link centre above ground -->
  <xacro:property name="body_z_spawn"     value="0.1029"/>  <!-- wheel_radius + body_size/2 -->

  <!-- ── base_footprint (virtual, ground-level) ─────────────────────────── -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <!-- base_link centre is body_z_spawn above the ground footprint -->
    <origin xyz="0 0 ${body_z_spawn}" rpy="0 0 0"/>
  </joint>

  <!-- ── base_link (cube body) ──────────────────────────────────────────── -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_size} ${body_size} ${body_size}"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${body_size} ${body_size} ${body_size}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <!-- Solid cube: I = m·s²/6 = 5.0·0.1397²/6 ≈ 0.01627 each axis -->
      <inertia ixx="0.01627" ixy="0.0" ixz="0.0"
               iyy="0.01627" iyz="0.0"
               izz="0.01627"/>
    </inertial>
  </link>

  <!-- ── Left wheel ─────────────────────────────────────────────────────── -->
  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <!-- Solid cylinder: Ixx=Iyy=m(3r²+h²)/12, Izz=mr²/2 -->
      <inertia ixx="0.000149" ixy="0.0" ixz="0.0"
               iyy="0.000149" iyz="0.0"
               izz="0.000272"/>
    </inertial>
  </link>

  <!-- wheel axis at the bottom face of the body: z = -body_size/2 = -0.0699 -->
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_left_link"/>
    <origin xyz="0 ${wheel_y} ${-body_size/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ── Right wheel ────────────────────────────────────────────────────── -->
  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.000149" ixy="0.0" ixz="0.0"
               iyy="0.000149" iyz="0.0"
               izz="0.000272"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_right_link"/>
    <origin xyz="0 ${-wheel_y} ${-body_size/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ── Caster wheel (passive ball, zero friction) ─────────────────────── -->
  <!--   x = body_size/2 - caster_radius = 0.0699 - 0.0165 = 0.0534 m       -->
  <!--   z = caster_radius - body_z_spawn = 0.0165 - 0.1029 = -0.0864 m     -->
  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="light_grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_link"/>
    <!-- Front of base, sphere centre at ground level -->
    <origin xyz="0.0534 0 -0.0864" rpy="0 0 0"/>
  </joint>

  <!-- ── laser_frame (2-D LiDAR, on top of body) ───────────────────────── -->
  <!--   z = +body_size/2 = +0.0699 m relative to base_link centre          -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_frame"/>
    <origin xyz="0 0 ${body_size/2}" rpy="0 0 0"/>
  </joint>

  <!-- ── camera_frame (front-top corner of body) ───────────────────────── -->
  <!--   x = body_size/2 = 0.0699 m (front face)                            -->
  <!--   z = body_size/2 = 0.0699 m (top face)                              -->
  <link name="camera_frame">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_frame"/>
    <origin xyz="${body_size/2} 0 ${body_size/2}" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════════════════════════════════════════════════════
       Gazebo Harmonic (gz-sim) plugins
       (active only when this xacro is loaded directly by Gazebo; in the
        simulation launch the SDF is used for spawning instead)
       ══════════════════════════════════════════════════════════════════════ -->

  <!-- Differential drive controller ──────────────────────────────────────── -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <!-- Topics (bridged to ROS 2 by ros_gz_bridge) -->
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <min_velocity>-0.5</min_velocity>
      <max_velocity>0.5</max_velocity>
      <min_acceleration>-1.0</min_acceleration>
      <max_acceleration>1.0</max_acceleration>
    </plugin>

    <!-- Joint state publisher for wheel joints -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>wheel_left_joint</joint_name>
      <joint_name>wheel_right_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- Zero friction on the caster so it slides freely ───────────────────── -->
  <gazebo reference="caster_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- 2-D LiDAR (360°, 10 Hz, 12 m range) ─────────────────────────────── -->
  <gazebo reference="laser_frame">
    <sensor name="lidar" type="gpu_lidar">
      <topic>/scan</topic>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>false</visualize>
      <gz_frame_id>laser_frame</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

</robot>
